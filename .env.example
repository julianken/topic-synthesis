# Copy to .env and adjust. `.env` is gitignored; values here are non-secret dev
# defaults or empty placeholders for secrets you supply locally.

# Postgres (matches docker-compose.yml defaults)
POSTGRES_USER=topic
POSTGRES_PASSWORD=topic_dev
POSTGRES_DB=topic_synthesis
# Host port 5433 by default to avoid clashing with a local Postgres on 5432.
POSTGRES_PORT=5433
REDIS_PORT=6379

# App database connection (used by src/store) — matches POSTGRES_PORT above.
DATABASE_URL=postgresql://topic:topic_dev@localhost:5433/topic_synthesis

# ── LLM providers (Vercel AI SDK) ─────────────────────────────────────
# The pipeline is provider-neutral: a workflow_version pins {provider, model}
# per stage. Supply a key only for the providers your arms actually use.
# VALIDATED / eval / CI runs REQUIRE real API keys (the claudeception `claude -p`
# dev path is a free local-sanity hatch only — never the validated path).
# None of these are needed to build/test.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# Local OpenAI-compatible server (Ollama / vLLM / proxy) for the `local` provider.
LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
LOCAL_OPENAI_API_KEY=not-needed

# Trigger.dev self-host — wired in the engine PR.
# TRIGGER_API_URL=http://localhost:3030
# TRIGGER_SECRET_KEY=
