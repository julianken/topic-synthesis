{
  "name": "topic-synthesis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint:boundaries": "depcruise src --config config/dependency-cruiser.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/store/migrate.ts",
    "build:job": "esbuild src/eval/run-job.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=dist/job/run-job.js",
    "skeleton": "tsx src/eval/run-skeleton.ts",
    "job": "tsx src/eval/run-job.ts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.85",
    "@ai-sdk/google": "3.0.83",
    "@ai-sdk/openai": "3.0.73",
    "@ai-sdk/openai-compatible": "2.0.51",
    "@google-cloud/run": "^3.3.0",
    "ai": "6.0.208",
    "dotenv": "17.4.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "next": "16.2.9",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eleatic/eval": "^0.1.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dependency-cruiser": "17.4.3",
    "esbuild": "^0.28.1",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
