# Dependencies
node_modules/

# Next.js
.next/
out/
build/
next-env.d.ts

# Compiled job bundle (Dockerfile.job's `npm run build:job` output) — a build artifact, never committed
dist/

# TypeScript
*.tsbuildinfo

# Misc
.DS_Store
*.log
.env
.env*.local

# Bootstrap fill answers (local; the filled files are the record)
.seed/answers.json

# Process artifacts / scratch (analysis, funnel, scratch output) — never the curated repo
tmp/

# Generated eval store (the @eleatic/eval SQLite DB, incl. `--trace <path>` output + WAL sidecars) — a build artifact, never committed, never under src/
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite-journal
.eval/

# Session tooling (not part of the app)
.remember/
.superpowers/
.playwright-mcp/

# Playwright e2e: the RUN artifacts are ignored, but the COMMITTED visual baselines
# (e2e/**/*-snapshots/*.png) are checked in by design — they ARE the visual contract,
# not the screenshot-paste flow the PR template governs. Do not ignore the snapshots dir.
/playwright-report/
/test-results/
/blob-report/
/playwright/.cache/
.last-run.json

# Claude Code: repo-local agents/skills ARE committed; per-developer settings and agent worktrees are not
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# Cursor: commit shared config (rules/agents/commands) if ever added; ignore per-developer state.
# Do NOT blanket-ignore .cursor/ — that would hide a future committed pointer/config.
.cursor/mcp.json

# Terraform (IaC in infra/): local provider cache + state stay out of git; the lock file IS committed.
infra/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
